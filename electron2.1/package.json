{
  "name": "navfit26",
  "version": "1.0.0",
  "description": "Modern version of NAVFIT98A",
  "homepage": "https://github.com/tatemurphy12/navfit26",
  "repository": "https://github.com/tatemurphy12/navfit26",
  "main": "main.js",
  "author": "Tate Murphy <jtatemurphy@gmail.com>",
  "license": "ISC",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "icon": "assets/logo",
    "appId": "com.Tate.NAVFIT26",
    "productName": "NAVFIT26",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "frontend_build/**/*",
      "backend_src/**/*",
      "assets/logo.png"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "templates",
        "to": "templates",
        "filter": [
          "**/*"
        ]
      }
    ],
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Office"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.2.1",
    "navfit26-master": "file:..",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^24.13.3"
  }
}
